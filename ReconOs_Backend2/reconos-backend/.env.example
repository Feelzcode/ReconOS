# ReconOs Backend — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git

# ── DATABASE ──────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/reconos"

# ── JWT ───────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-change-this"
JWT_REFRESH_EXPIRES_IN="7d"

# ── NOMBA API ─────────────────────────────────
# Get these from Nomba during onboarding week (June 24-29)
NOMBA_BASE_URL="https://sandbox.api.nomba.com/v1"   # sandbox during hackathon — switch to https://api.nomba.com/v1 only after KYC/certification
NOMBA_CLIENT_ID=""
NOMBA_CLIENT_SECRET=""
NOMBA_WEBHOOK_SECRET=""   # for HMAC-SHA256 signature verification (header: "nomba-signature")
NOMBA_ACCOUNT_ID=""       # your PARENT merchant account id — sent as the "accountId" header on every call (confirmed: Nomba's own docs say "authenticate with the parent Account ID in the accountId header")
NOMBA_SUBACCOUNT_ID=""    # the sub-account id from your sandbox credentials — Nomba confirms you must "scope your calls to your sub-account ID" in addition to the parent header. Exact field name/location for that scoping is unconfirmed against a live response; we send it as a `subAccountId` body field (or query param on GET requests) as our best guess. Leave blank to disable — every call works fine without it, this just adds the extra scoping field when set.

# ── ANTHROPIC (Claude API) ────────────────────
ANTHROPIC_API_KEY=""

# ── EMAIL (Resend) ────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=""
# MUST use a domain you verified at https://resend.com/domains
# onboarding@resend.dev only works for testing TO YOUR OWN Resend login email.
EMAIL_FROM="ReconOS <billing@your-verified-domain.com>"
# Login OTP email step (set false to skip in local dev)
AUTH_OTP_ENABLED="true"

# ── APP ───────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ── MOCK MODE ─────────────────────────────────
# Set to "true" before onboarding (June 23).
# Switch to "false" on July 1 when real keys arrive.
USE_MOCK_NOMBA="true"

# ── DEMO MODE (POST /webhooks/mock) ───────────
# SECURITY: this endpoint can fabricate "payment received" events that
# mark real invoices as PAID. Both of these must be set correctly or the
# endpoint is locked. Set DEMO_MODE_ENABLED="false" and leave the secret
# blank as soon as Demo Day is over — do not leave this on in production
# indefinitely.
DEMO_MODE_ENABLED="true"
DEMO_MODE_SECRET="generate-a-random-string-and-put-it-here"
