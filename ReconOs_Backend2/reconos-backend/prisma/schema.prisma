// ReconOs - Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ORGANIZATIONS
// Multi-tenant: one org per merchant account
// ─────────────────────────────────────────────
model Organization {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  email     String   @unique

  // Industry-native UI labels (DB model stays Customer / Invoice)
  industryTemplate String?  // education | property | healthcare | logistics | custom
  customerLabel    String   @default("Customers")
  invoiceLabel     String   @default("Invoices")

  // Nomba treasury — one sub-account per merchant org (created via API, not dashboard)
  nombaSubAccountId String?  // Nomba UUID for this org's ledger
  nombaAccountRef   String?  @unique // stable ref we pass to Nomba (e.g. reconos_{orgId})

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  customers    Customer[]
  invoices     Invoice[]
  auditLogs    AuditLog[]

  @@map("organizations")
}

// ─────────────────────────────────────────────
// USERS
// Merchant accounts tied to an organization
// ─────────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  auditLogs    AuditLog[]

  @@index([organizationId])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────
// CUSTOMERS
// Each customer gets a dedicated Nomba VA
// ─────────────────────────────────────────────
model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?

  // Nomba virtual account details
  virtualAccountNumber String?  @unique
  virtualAccountName   String?
  bankName             String?  @default("Wema Bank")
  nombaAccountId       String?  // Nomba's internal VA id

  // Wallet credit from resolved overpayments — applied to future invoices
  walletBalance Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization        Organization        @relation(fields: [organizationId], references: [id])
  invoices            Invoice[]
  transactions        Transaction[]
  overpaymentActions  OverpaymentAction[]

  @@index([organizationId])
  @@index([virtualAccountNumber])
  @@map("customers")
}

// ─────────────────────────────────────────────
// INVOICES
// Full lifecycle: PENDING → PAID / OVERDUE
// ─────────────────────────────────────────────
model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String
  invoiceNumber  String        @unique // e.g. INV-0291
  description    String        // e.g. Term 2 school fees, Caution fee
  amount         Decimal       @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(12, 2) // running total of all matched payments
  status         InvoiceStatus @default(PENDING)
  dueDate        DateTime
  notes          String?
  paymentToken   String?       @unique // public link token for customer payment page
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization      Organization          @relation(fields: [organizationId], references: [id])
  customer           Customer             @relation(fields: [customerId], references: [id])
  matches            ReconciliationMatch[]
  overpaymentActions OverpaymentAction[]

  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  OVERPAID
}

// ─────────────────────────────────────────────
// TRANSACTIONS
// Inbound payments from Nomba webhook events
// ─────────────────────────────────────────────
model Transaction {
  id              String            @id @default(cuid())
  customerId      String?           // null if unidentified sender
  nombaReference  String            @unique // Nomba's payment reference
  nombaEventId    String            @unique // for idempotency
  amount          Decimal           @db.Decimal(12, 2)
  accountNumber   String            // the VA that received the payment
  payerName       String?           // sender name from Nomba
  payerAccount    String?           // sender account number
  payerBankName   String?           // sender's bank name, e.g. "Access Bank" — captured from webhook for refund routing
  payerBankCode   String?           // sender's bank CBN code, if Nomba includes it — needed for /transfers/bank/lookup
  paymentDate     DateTime
  status          TransactionStatus @default(UNMATCHED)
  rawWebhookData  Json              // full Nomba payload stored as-is
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  customer  Customer?            @relation(fields: [customerId], references: [id])
  match     ReconciliationMatch?
  exception Exception?
  overpaymentActions OverpaymentAction[]

  @@index([customerId])
  @@index([accountNumber])
  @@index([nombaEventId])   // critical for idempotency lookup
  @@index([status])
  @@index([paymentDate])
  @@map("transactions")
}

enum TransactionStatus {
  UNMATCHED
  MATCHED
  IN_REVIEW
  EXCEPTION
  MANUALLY_MATCHED
}

// ─────────────────────────────────────────────
// RECONCILIATION MATCHES
// The core output of the matching engine
// ─────────────────────────────────────────────
model ReconciliationMatch {
  id            String      @id @default(cuid())
  invoiceId     String
  transactionId String      @unique
  
  // Scoring breakdown (each out of max points)
  scoreAmount    Int         @default(0)  // max 60
  scoreCustomer  Int         @default(0)  // max 25
  scoreTime      Int         @default(0)  // max 10
  scoreReference Int         @default(0)  // max 5
  confidenceScore Int        // total 0-100

  matchReason   String?     // human-readable explanation seed
  autoMatched   Boolean     @default(false)
  aiExplanation String?     // async-filled by Claude API
  
  // Override tracking
  overriddenBy  String?     // user id who overrode
  overrideReason String?
  overriddenAt  DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  invoice     Invoice     @relation(fields: [invoiceId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([invoiceId])
  @@index([confidenceScore])
  @@map("reconciliation_matches")
}

// ─────────────────────────────────────────────
// OVERPAYMENT ACTIONS
// Tracks how an overpayment was resolved:
// refund, wallet credit, or applied to a future invoice
// ─────────────────────────────────────────────
model OverpaymentAction {
  id            String                  @id @default(cuid())
  invoiceId     String
  customerId    String
  transactionId String                  // the payment that caused the overpayment — needed to re-verify via Nomba's Transactions API before refunding
  excessAmount  Decimal                 @db.Decimal(12, 2) // amount paid beyond invoice total
  actionType    OverpaymentActionType
  status        OverpaymentActionStatus @default(PENDING)

  // Filled depending on actionType
  appliedToInvoiceId String? // for APPLY_TO_FUTURE_INVOICE
  refundReference     String? // for REFUND — bank transfer reference once sent
  transferStatus      String? // raw status returned by Nomba: successful / pending / failed
  failureReason       String? // populated if the Nomba transfer call threw or returned failed
  notes               String?

  resolvedBy String? // user id who chose the action
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  invoice     Invoice     @relation(fields: [invoiceId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([invoiceId])
  @@index([customerId])
  @@index([transactionId])
  @@index([status])
  @@map("overpayment_actions")
}

enum OverpaymentActionType {
  REFUND
  CREDIT_WALLET
  APPLY_TO_FUTURE_INVOICE
}

enum OverpaymentActionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────
// EXCEPTIONS
// Unmatched or suspicious transactions
// ─────────────────────────────────────────────
model Exception {
  id            String          @id @default(cuid())
  transactionId String          @unique
  type          ExceptionType
  description   String
  aiSummary     String?         // async-filled by Claude API
  status        ExceptionStatus @default(OPEN)
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([status])
  @@map("exceptions")
}

enum ExceptionType {
  NO_MATCH          // no invoice found
  AMOUNT_MISMATCH   // amount doesn't match any invoice
  UNKNOWN_SENDER    // VA not linked to any customer
  ANOMALY           // unusual amount or pattern
  DUPLICATE         // possible duplicate payment
}

enum ExceptionStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  IGNORED
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// Immutable record of every system action
// ─────────────────────────────────────────────
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?  // null for system actions (e.g. auto-match)
  action         String   // e.g. INVOICE_CREATED, MATCH_AUTO, OVERRIDE_APPLIED
  entity         String   // e.g. Invoice, Transaction, Match
  entityId       String
  oldValue       Json?    // before state
  newValue       Json?    // after state
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
